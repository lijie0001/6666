FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py crawler.py image_crawler.py .
COPY templates/ templates/

ENV PORT=5000
EXPOSE 5000

# 使用 gunicorn 生产服务器，Railway 会注入 PORT
CMD ["sh", "-c", "gunicorn --bind 0.0.0.0:${PORT:-5000} --workers 1 --threads 2 --timeout 60 app:app"]
