# 复制此文件为 .env 并填入配置
# TELEGRAM_BOT_TOKEN=你的机器人token
# TELEGRAM_PROXY=  # 国内需代理，如 http://127.0.0.1:7890
# OPENAI_API_KEY=  # OpenAI API Key，用于 AI 回复
# OPENAI_BASE_URL=  # 可选，国内可用镜像如 https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo  # 可选，默认 gpt-3.5-turbo

# 群组爬虫（telegram_crawler.py）
# TELEGRAM_API_ID=     # 从 https://my.telegram.org 获取
# TELEGRAM_API_HASH=   # 从 https://my.telegram.org 获取
# TELEGRAM_PHONE=      # 手机号，如 +8613800138000
# CRAWLER_SOURCE=      # 源群组 ID（如 -1001234567890）或 @用户名
# CRAWLER_TARGET=      # 目标群组 ID 或 @用户名
